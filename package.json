{
  "name": "qa-test-generator",
  "version": "0.1.0",
  "private": true,
  "description": "Platform for generating Cypress test projects with AI assistance",
  "workspaces": [
    "packages/core",
    "packages/cli"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:core": "npm run build --workspace @qa-test-generator/core",
    "build:cli": "npm run build --workspace @qa-test-generator/cli",
    "dev:cli": "npm run dev --workspace @qa-test-generator/cli",
    "qa": "node packages/cli/dist/index.js",
    "clean": "rimraf packages/*/dist packages/*/node_modules"
  },
  "devDependencies": {
    "marked": "^18.0.5",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  }
}
